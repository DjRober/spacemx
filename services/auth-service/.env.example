# Copia este archivo a .env y rellena los valores (el .env NO se versiona)
PORT=3005

# Secreto para firmar los JWT. Usa una cadena larga y aleatoria en producción.
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=24h

# Conexión a PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/spacemex