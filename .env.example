# Variables del orquestador (docker-compose.yml).
# Cópialo a .env en la raíz:  cp .env.example .env
#
# docker compose lee el .env de la raíz automáticamente. Todo tiene default,
# así que `docker compose up` funciona aunque no crees este archivo; el .env
# solo sirve para poner tu llave real de NASA y un JWT_SECRET propio.
#
# Este .env de la raíz es SOLO para Docker. Si corres los servicios a mano
# con `npm run dev`, cada servicio usa su propio .env (ver services/README.md).

# ── NASA ────────────────────────────────────────────────────────
# La usan apod-service y neows-service. Llave gratis en https://api.nasa.gov
# DEMO_KEY sirve para probar, pero solo permite 30 peticiones por hora.
NASA_API_KEY=DEMO_KEY

# ── JWT ─────────────────────────────────────────────────────────
# auth-service firma los tokens y reports-service los valida:
# el valor DEBE ser el mismo para los dos (el compose ya se encarga).
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=24h

# ── PostgreSQL ──────────────────────────────────────────────────
# Credenciales del contenedor de Postgres. El compose arma el DATABASE_URL
# de auth-service y reports-service a partir de estas tres variables.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=spacemex
